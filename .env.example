# Copy this file to `.env` and adjust values for your environment.
# `.env` is gitignored; never commit real secrets.

# --- Django ---
# Generate a fresh key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# --- Database ---
# POSTGRES_* are consumed by the docker-compose Postgres service.
# DATABASE_URL is consumed by Django and must stay consistent with them.
POSTGRES_DB=amopromo
POSTGRES_USER=amopromo
POSTGRES_PASSWORD=amopromo
POSTGRES_PORT=5432
DATABASE_URL=postgres://amopromo:amopromo@localhost:5432/amopromo

# --- External airports API (Problem 1 import source) ---
# Basic Auth credentials and API key are provided by the AmoPromo challenge.
# Fill these in your local .env; do not commit real values.
AIRPORT_API_BASE_URL=https://stub.amopromo.com/air/airports
AIRPORT_API_KEY=your-api-key
AIRPORT_API_USER=your-username
AIRPORT_API_PASSWORD=your-password
AIRPORT_API_TIMEOUT=10
